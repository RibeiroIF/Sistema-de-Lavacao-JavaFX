	<dataset name="tableDataset" uuid="9654ef2a-1123-45ab-a77d-bb998150fa6d">
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="RelatorioOS"/>
		<parameter name="SUB_ID_OS" class="java.lang.Integer"/>
		<query language="SQL"><![CDATA[SELECT i.valor_servico, s.descricao
FROM item_os i
INNER JOIN servico s ON i.id_servico = s.id
WHERE i.id_ordemservico = $P{SUB_ID_OS};]]></query>
		<field name="valor_servico" class="java.lang.Double"/>
		<field name="descricao" class="java.lang.String"/>
	</dataset>
	<parameter name="PAR_ID_OS" class="java.lang.Integer"/>
	<query language="sql"><![CDATA[SELECT os.id AS os_id, os.numero, os.agenda, os.total, os.desconto, os.status,
       v.placa, m.descricao AS modelo, c.nome AS cliente
FROM ordem_servico os
INNER JOIN veiculo v ON os.id_veiculo = v.id
INNER JOIN modelo m ON v.id_modelo = m.id
INNER JOIN cliente c ON v.id_cliente = c.id
WHERE os.id = $P{PAR_ID_OS};]]></query>
	<field name="os_id" class="java.lang.Integer"/>
	<field name="numero" class="java.lang.Long"/>
	<field name="agenda" class="java.sql.Date"/>
	<field name="total" class="java.lang.Double"/>
	<field name="desconto" class="java.lang.Double"/>
	<field name="status" class="java.lang.String"/>
	<field name="placa" class="java.lang.String"/>
	<field name="modelo" class="java.lang.String"/>
	<field name="cliente" class="java.lang.String"/>
