        </GridPane>
        <Group layoutX="296.0" layoutY="290.0" AnchorPane.bottomAnchor="20.0" AnchorPane.rightAnchor="20.0">
            <children>
                <Button fx:id="buttonConfirmar" layoutX="-22.0" mnemonicParsing="false" onAction="#handleButtonConfirmar" prefHeight="26.0" prefWidth="88.0" text="Confirmar" />
                <Button fx:id="buttonCancelar" layoutX="75.0" mnemonicParsing="false" onAction="#handleButtonCancelar" prefHeight="26.0" prefWidth="88.0" text="Cancelar" />
            </children>
        </Group>
      <Label layoutX="163.0" layoutY="21.0" prefHeight="27.0" prefWidth="139.0" text="Ordem de Serviço:">
         <font>
            <Font name="System Bold" size="16.0" />
         </font>
      </Label>
    </children>
</AnchorPane>
