<AnchorPane id="AnchorPane" prefHeight="440.0" prefWidth="465.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.ifsc.fln.controller.FXMLAPProcessoOrdemServicoDialogController">
    <children>
        <GridPane layoutX="23.0" layoutY="55.0" prefHeight="309.0" prefWidth="418.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="147.0" minWidth="10.0" prefWidth="77.0" />
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="349.0" minWidth="10.0" prefWidth="337.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints maxHeight="38.0" minHeight="0.0" prefHeight="21.0" vgrow="SOMETIMES" />
                <RowConstraints maxHeight="86.0" minHeight="10.0" prefHeight="24.0" vgrow="SOMETIMES" />
                <RowConstraints maxHeight="109.0" minHeight="10.0" prefHeight="28.0" valignment="CENTER" vgrow="NEVER" />
                <RowConstraints maxHeight="125.0" minHeight="10.0" prefHeight="123.0" vgrow="SOMETIMES" />
                <RowConstraints maxHeight="28.0" minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints maxHeight="28.0" minHeight="10.0" prefHeight="28.0" vgrow="SOMETIMES" />
                <RowConstraints maxHeight="28.0" minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Label text="Veículo" GridPane.halignment="RIGHT">
                    <GridPane.margin>
                        <Insets right="5.0" />
                    </GridPane.margin>
                </Label>
                <Label text="Data:" GridPane.halignment="RIGHT" GridPane.rowIndex="1">
                    <GridPane.margin>
                        <Insets right="5.0" />
                    </GridPane.margin>
                </Label>
                <Label text="Serviço" GridPane.halignment="RIGHT" GridPane.rowIndex="2" GridPane.valignment="CENTER" GridPane.vgrow="NEVER">
                    <GridPane.margin>
                        <Insets right="5.0" />
                    </GridPane.margin>
                </Label>
                <Label text="Itens:" GridPane.halignment="RIGHT" GridPane.rowIndex="3">
                    <GridPane.margin>
                        <Insets right="5.0" />
                    </GridPane.margin>
                </Label>
                <Label text="Valor:" GridPane.halignment="RIGHT" GridPane.rowIndex="5">
                    <GridPane.margin>
                        <Insets right="5.0" />
                    </GridPane.margin>
                </Label>
                <ComboBox fx:id="comboBoxVeiculos" prefHeight="25.0" prefWidth="365.0" promptText="Selecione o veículo..." GridPane.columnIndex="1" />
                <DatePicker fx:id="datePickerAgenda" prefHeight="25.0" prefWidth="355.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                <TableView fx:id="tableViewItens" onMouseClicked="#handleTableViewMouseClicked" prefHeight="200.0" prefWidth="367.0" GridPane.columnIndex="1" GridPane.rowIndex="3">
                    <columns>
                        <TableColumn fx:id="tableColumnServico" prefWidth="211.0" text="Serviço" />
                        <TableColumn fx:id="tableColumnValor" prefWidth="125.0" text="Valor" />
                    </columns>
                    <contextMenu>
                        <ContextMenu fx:id="contextMenuTableView">
                            <items>
                                <MenuItem fx:id="contextMenuItemRemoverItem" mnemonicParsing="false" onAction="#handleContextMenuItemRemoverItem" text="Remover item" />
                            </items>
                        </ContextMenu>
                    </contextMenu>
                </TableView>
                <TextField fx:id="tfValorTotal" alignment="CENTER_RIGHT" editable="false" promptText="Total" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                <HBox prefHeight="100.0" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                    <children>
                        <ComboBox fx:id="comboBoxServico" prefHeight="25.0" prefWidth="205.0" promptText="Selecione o serviço..." />
                        <TextField fx:id="tfValorServico" prefHeight="25.0" prefWidth="83.0" />
                        <Button fx:id="buttonAdicionar" mnemonicParsing="false" onAction="#handleButtonAdicionar" prefHeight="25.0" prefWidth="77.0" text="Adicionar" />
                    </children>
                </HBox>
                <Label alignment="CENTER_RIGHT" prefHeight="18.0" prefWidth="82.0" text="Desconto (%):" GridPane.rowIndex="4">
                    <GridPane.margin>
                        <Insets right="5.0" />
                    </GridPane.margin>
                </Label>
                <TextField fx:id="tfDesconto" alignment="CENTER_RIGHT" promptText="0,0" text="0,0" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                <Label alignment="CENTER_RIGHT" prefHeight="18.0" prefWidth="82.0" text="Status" GridPane.rowIndex="6">
                    <GridPane.margin>
                        <Insets right="5.0" />
                    </GridPane.margin>
                </Label>
                <ChoiceBox fx:id="choiceBoxStatus" prefHeight="26.0" prefWidth="340.0" GridPane.columnIndex="1" GridPane.rowIndex="6" />
